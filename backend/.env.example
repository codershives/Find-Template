PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/nexlance
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# SMTP email settings for forgot-password OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-app-password
SMTP_FROM="Find Template <your-email@example.com>"
PASSWORD_RESET_OTP_EXPIRES_MINUTES=10

# Square sandbox payment settings
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your-square-sandbox-access-token
SQUARE_LOCATION_ID=your-square-sandbox-location-id
SQUARE_CURRENCY=USD
